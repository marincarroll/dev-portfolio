---
import { basics } from "@cv";

import Layout from "../layouts/Layout.astro";
import Mail from "../icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import type { SocialIcon } from "@/types";

const SOCIAL_ICONS: SocialIcon = {
    GitHub,
    LinkedIn,
};
const { profiles, phone, email } = basics;

const linkedInfo = profiles.find(({ network }) => network === "LinkedIn");
const linkedUrl = linkedInfo?.url;

const printInfo = [email, phone, linkedUrl].filter(Boolean).join(" • ");
---
<Layout title="Contact" pageName="contact">
    <div class="print">
        {printInfo}
    </div>
    <div class="no-print">
        {
            email && (
                <a href={`mailto:${email}`} target="_blank" rel="noopener noreferrer">
                    <Mail /> Email me
                </a>
            )
        }
        {
            profiles.map(({ network, url }) => {
                const Icon = SOCIAL_ICONS[network];

                return (
                    <a href={url} target="_blank" rel="noopener noreferrer">
                        <Icon />
                        {network}
                    </a>
                );
            })
        }
    </div>
</Layout>
<style>
    :global(.page):before,
    :global(.page):after {
        background: var(--color--foreground);
        height: var(--border-height);
        content: '';
        position: absolute;
        left: var(--border-height);
        right: var(--border-height);
    }

    :global(.page):before {
        top: 0;
        border-radius: 0 0 var(--border-height) var(--border-height);
    }

    :global(.page):after {
        bottom: 0;
        border-radius: var(--border-height) var(--border-height)  0 0 ;
    }
</style>