---
import verticalSlide from "../animations/vertical-slide";
import Navigation from "../components/Navigation.astro";

const { pageName } = Astro.props;
---
<section class:list={['page', pageName]} transition:animate={verticalSlide}>
    <div class="page__content">
        <slot/>
    </div>
    <Navigation currentItem={pageName} />
</section>
<style>
    .page {
        height: 100vh;
        background: var(--color--background);
        color: var(--color--foreground);
        display: flex;
        flex-direction: column;
        padding: var(--border-height);
        overflow: hidden;
    }

    .page__content {
        padding: var(--nav-height);
    }

    @keyframes enterUp {
        from {
            transform: translateY(100%);
        }
    }

    @keyframes exitUp {
        to {
            transform: translateY(-100%);
        }
    }

    @keyframes enterDown {
        from {
            transform: translateY(-100%);
        }
    }

    @keyframes exitDown {
        to {
            transform: translateY(100%);
        }
    }
</style>