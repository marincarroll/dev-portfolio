---
import { verticalSlide } from "../animations/vertical-slide";
import Navigation from "../components/Navigation.astro";

const { pageName } = Astro.props;
---
<section class:list={['page', pageName]} transition:animate={verticalSlide}>
    <div class="page__content">
        <slot/>
    </div>
    <Navigation currentItem={pageName} />
</section>
<style>
    .page {
        height: 100vh;
        background: var(--color--foreground);
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow: hidden;
    }

    .page__content {
        background: var(--color--background);
        color: var(--color--foreground);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--nav-height);
        max-height: 100%;
        width: 100%;
        flex: 1;
    }


    .about {
        --color--foreground: var(--color--dark);
        --color--background: var(--color--light);
    }

    .about {
        padding: var(--border-height);
    }

    .about .page__content {
        border-radius: var(--border-height);
    }

  /*  .page.resume:after {
        --color--foreground: var(--color--dark);
    }

    .page.resume:after,
    .page.contact:before {
        max-width: 45em;
       left: var(--nav-height);
    }*/

    :global( .resume .navigation__tab[data-direction="down"] ) {
        --color--foreground: var(--color--dark);
        --color--background: var(--color--light);
    }

    .resume .page__content {
        padding-block: 10em 0;
        align-items: start;
        flex-direction: column;
    }


    @keyframes slideUp {
        to {
            transform: translateY(-100%);
        }
    }

    @keyframes slideDown {
        to {
            transform: translateY(100%);
        }
    }
</style>