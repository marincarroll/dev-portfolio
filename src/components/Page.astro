---
import Navigation from "./Navigation.astro";
const { className, id } = Astro.props;
const anim = {
    old: {
        name: 'exit',
        duration: '0.5s',
    },
    new: {
        name: 'enter',
        duration: '0.5s',
    },
};

const customTransition = {
    forwards: anim,
    backwards: anim,
};
---

<section id={id} class:list={['page', className]} transition:animate={customTransition}>
    <Navigation currentItem={id}/>
    <div class="page__inner">
        <slot/>
    </div>
</section>
<style>
    .page {
        /*      scroll-snap-align:  center;*/
        top: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100vh;
        padding: 10vmin;
    //  position: sticky;
    }

    .page__inner {
        max-height: 80%;
        width: 100%;
        max-width: 70em;
        overflow: hidden;
    //   padding: 5em;
        border-radius: 35px;
    }

    @keyframes enter {
        from {
            transform: translateY(100%);
        }
    }

    @keyframes exit {
        to {
            transform: translateY(-100%);
        }
    }
</style>
<script is:inline>
   /* document.addEventListener('astro:before-swap', event => {
        event.swap = () => {
       //   alert('stuff'); determine animation direction here
        };
    });*/
</script>